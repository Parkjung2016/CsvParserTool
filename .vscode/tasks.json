{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/CSVParserTool.slnx",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean",
      "command": "dotnet",
      "type": "process",
      "args": ["clean", "${workspaceFolder}/CSVParserTool.slnx", "-c", "Debug"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run DataToolGUI",
      "command": "dotnet",
      "type": "process",
      "args": ["run", "--project", "${workspaceFolder}/CSVParserTool.csproj", "-c", "Debug", "--no-launch-profile"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "dependsOn": ["build"],
      "dependsOrder": "sequence"
    },
    {
      "label": "run DataTool CLI (help)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/DataTool.Cli/DataTool.Cli.csproj",
        "-c",
        "Debug",
        "--no-launch-profile",
        "--",
        "--help"
      ],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "dependsOn": ["build"],
      "dependsOrder": "sequence"
    }
  ]
}
